{
  "name": "@fifa/db",
  "version": "1.0.0",
  "private": true,
  "description": "Drizzle ORM schema, migrations and real-data seed for the FIFA 2026 platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "generate": "drizzle-kit generate",
    "migrate": "node dist/migrate.js",
    "seed": "node dist/seed.js",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.0",
    "@fifa/shared": "1.0.0",
    "bcryptjs": "^3.0.2",
    "drizzle-orm": "^0.44.7",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.7.2"
  }
}
