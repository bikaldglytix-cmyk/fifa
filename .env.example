# ---- API (apps/api) — copy to .env for local dev; set as env vars on Render ----

# Postgres connection string (Supabase: Project Settings → Database → Connection string).
# Omit locally to use embedded PGlite at .pgdata (dev only — not persistent on PaaS disks).
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Comma-separated browser origins allowed by CORS + socket.io (production: your Vercel URL)
WEB_ORIGINS=http://localhost:3100,http://127.0.0.1:3100

# Supabase project (end-user identity provider; local RS256 remains for ops/e2e)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Comma-separated emails promoted to admin on first Supabase sign-in
ADMIN_EMAILS=you@example.com

# Optional — only if the Supabase project still issues legacy HS256 JWTs
# SUPABASE_JWT_SECRET=

# Optional — pin the local RS256 JWT keypair (PEM content, "\n" escapes ok).
# If unset, keys auto-generate into .keys/ (regenerated per deploy on ephemeral disks).
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=

# Optional tuning
# PORT=4000
# RESULT_FEEDS=
# LIVE_FEED=on
# DISABLE_SCHEDULER=
