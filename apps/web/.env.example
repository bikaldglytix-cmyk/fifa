# ---- Web (apps/web) — copy to .env.local for local dev; set in Vercel project env ----

# Supabase project (must match the API's SUPABASE_URL)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# API base used by Next.js rewrites for /api/v1 and /graphql (server-side proxy).
# Local default: http://localhost:4000. Production: your Render API URL.
API_INTERNAL_URL=http://localhost:4000

# socket.io connects DIRECTLY from the browser (websockets do not proxy through
# Vercel rewrites). Production: your Render API URL.
NEXT_PUBLIC_WS_URL=http://localhost:4000
