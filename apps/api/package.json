{
  "name": "@fifa/api",
  "version": "1.0.0",
  "private": true,
  "description": "FIFA 2026 platform API — NestJS: REST + GraphQL + WebSocket gateway",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start:dev": "tsc -p tsconfig.build.json && node dist/main.js",
    "start:prod": "node dist/main.js",
    "test:e2e": "npm run build && vitest run --config vitest.e2e.config.ts",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@apollo/server": "^5.0.0",
    "@as-integrations/express5": "^1.1.2",
    "@fifa/db": "1.0.0",
    "@fifa/shared": "1.0.0",
    "@fifa/sim-engine": "1.0.0",
    "@nestjs/apollo": "^13.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/graphql": "^13.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.3.0",
    "@nestjs/websockets": "^11.0.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "graphql": "^16.10.0",
    "graphql-subscriptions": "^3.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/qrcode": "^1.5.5",
    "typescript": "^5.7.2",
    "vitest": "^3.0.0"
  }
}
